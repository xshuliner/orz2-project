    "lint": "eslint src --fix",
    "format": "eslint src --fix && prettier --write \"src/**/*.{ts,tsx,js,jsx,css,json,md}\""
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.13.0",
